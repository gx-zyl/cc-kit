# Chrome DevTools WSL — 配置文件
# just 启动时自动加载，也作为 Python 脚本的环境变量来源
#
# 修改后只需重新 just start / just serve 即可生效

# Windows 工作目录：chrome_debug.py 部署位置 + Chrome profile 存放处
CCW_DIR=D:\chrome-devtools-wsl

# Windows Python 路径（留空则通过 PowerShell 自动查找：Get-Command python.exe）
# 如果自动查找失败，手动填写完整路径，例如：
# PYWIN=C:\Users\you\AppData\Local\Programs\Python\Python313\python.exe
PYWIN=

# Chrome CDP 调试端口
CDP_PORT=9222

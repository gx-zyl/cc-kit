# Chrome DevTools WSL — 管理 Windows Chrome 远程调试
# 配置项见 .env，just 启动时自动加载

script := "scripts/chrome_debug.py"
ccw_dir := env_var_or_default("CCW_DIR", "D:\\chrome-devtools-wsl")
pywin := env_var_or_default("PYWIN", "python.exe")
pwrsh := "powershell.exe -NoProfile -Command"
win_script := ccw_dir + "\\chrome_debug.py"

# 列出所有命令
default:
    @just --list

# 同步脚本到 CCW_DIR
copy:
    uv run python {{ script }} copy

# 启动 Chrome DevTools
start: copy
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' start"

# 关闭 Chrome
stop:
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' stop"

# 查看状态
status:
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' status"

# 打开 URL: just nav <url>
nav url="https://chatgpt.com":
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' nav '{{ url }}'"

# 执行 JS: just eval <code>
eval code="document.title":
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' eval '{{ code }}'"

# 截图: just shot [name]
shot name="screenshot":
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' shot '{{ name }}'"
    @wslpath -w "{{ ccw_dir }}" 2>/dev/null | xargs -I{} cp "{}\\{{ name }}.png" /tmp/{{ name }}.png 2>/dev/null; echo "同步到 /tmp/{{ name }}.png"

# 启动 web-access 兼容 API 服务（localhost:3456）
serve:
    uv run python3 scripts/cdp-bridge.py

# 向 ChatGPT 提问: just ask "你的问题"
ask question="今天有什么新闻?":
    {{ pwrsh }} "& '{{ pywin }}' '{{ win_script }}' ask '{{ question }}'"

# 放行 CDP 端口防火墙（弹 UAC）
firewall:
    {{ pwrsh }} "Start-Process wscript -ArgumentList '{{ ccw_dir }}\\firewall-off.vbs'"

# 编辑脚本
edit:
    @$EDITOR {{ script }}

# 清理工作目录
clean:
    {{ pwrsh }} "if (Test-Path '{{ ccw_dir }}') { Remove-Item '{{ ccw_dir }}' -Recurse -Force; Write-Output 'deleted' } else { Write-Output 'not found' }"

{
  "name": "claude-workflow-tools",
  "displayName": "Claude Workflow Tools",
  "description": "YAML workflow 语法高亮、变量引用追踪、schema 校验",
  "version": "0.1.0",
  "publisher": "claude-code",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages", "Linters"],

  "activationEvents": [
    "onLanguage:yaml"
  ],

  "contributes": {
    "grammars": [
      {
        "path": "./syntaxes/yaml-variables.json",
        "scopeName": "workflow-yaml.injection",
        "injectTo": ["source.yaml"],
        "embeddedLanguages": {
          "meta.template.variable": "plaintext"
        }
      }
    ],

    "languages": [
      {
        "id": "claude-workflow-yaml",
        "filenamePatterns": ["**/.claude/workflows/*.yml", "**/.claude/workflows/*.yaml"],
        "aliases": ["Claude Workflow"]
      }
    ],

    "snippets": [
      {
        "language": "claude-workflow-yaml",
        "path": "./snippets/workflow-snippets.json"
      }
    ],

    "themes": [
      {
        "label": "Claude Workflow Variables",
        "uiTheme": "vs-dark",
        "path": "./themes/workflow-colors.json"
      }
    ]
  },

  "main": "./extension.js",
  "dependencies": {
    "yaml": "^2.5.0"
  }
}

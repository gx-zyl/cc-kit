{
  "scopeName": "workflow-yaml.injection",
  "comment": "Injects {{variable}} highlighting into YAML strings",
  "injectionSelector": "L:source.yaml string.quoted.double.yaml",
  "patterns": [
    {
      "include": "#templateVars"
    },
    {
      "include": "#templateCondition"
    }
  ],
  "repository": {
    "templateVars": {
      "patterns": [
        {
          "match": "(\\{\\{)\\s*([a-zA-Z_][a-zA-Z0-9_.]*(?:\\.[a-zA-Z_][a-zA-Z0-9_.]*)*)\\s*(\\}\\})",
          "name": "meta.template.variable.workflow",
          "captures": {
            "1": { "name": "punctuation.definition.variable.begin.workflow" },
            "2": { "name": "variable.other.readwrite.workflow" },
            "3": { "name": "punctuation.definition.variable.end.workflow" }
          }
        },
        {
          "match": "(\\{\\{)\\s*(loop\\.(?:round|index|first|last)|item\\.\\w+|args\\.\\w+)\\s*(\\}\\})",
          "name": "meta.template.builtin.workflow",
          "captures": {
            "1": { "name": "punctuation.definition.variable.begin.workflow" },
            "2": { "name": "variable.other.builtin.workflow" },
            "3": { "name": "punctuation.definition.variable.end.workflow" }
          }
        }
      ]
    },
    "templateCondition": {
      "match": "(\\{\\{)\\s*(\\w+(?:\\.\\w+)*)\\s*(==|!=|>|<|>=|<=)\\s*(\\S+)\\s*(\\}\\})",
      "name": "meta.template.condition.workflow",
      "captures": {
        "1": { "name": "punctuation.definition.variable.begin.workflow" },
        "2": { "name": "variable.other.condition.workflow" },
        "3": { "name": "keyword.operator.comparison.workflow" },
        "4": { "name": "constant.other.condition-value.workflow" },
        "5": { "name": "punctuation.definition.variable.end.workflow" }
      }
    }
  }
}
